root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csproj,props,targets,slnx}]
indent_size = 4

[*.{json,yml,yaml,axaml,xml,proto}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

# C# house style. ASCII punctuation only (avoid-ai-artifacts). File-scoped namespaces.
# Explicit types everywhere - NO var (see the code-style-explicit memory). Target-typed `new()` is
# fine (the type is on the left). Elevated to warning so, under TreatWarningsAsErrors +
# EnforceCodeStyleInBuild, a stray `var` fails the build.
[*.cs]
csharp_style_namespace_declarations = file_scoped:warning
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:warning
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = false:warning
csharp_style_var_elsewhere = false:warning
dotnet_diagnostic.IDE0007.severity = warning
dotnet_diagnostic.IDE0008.severity = warning
dotnet_diagnostic.IDE0161.severity = warning
# Keep the rest of the IDE style ruleset advisory - do not fail the build on unrelated nits.
dotnet_analyzer_diagnostic.category-Style.severity = none
