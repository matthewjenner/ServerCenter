<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ServerCenter.Ui.MainWindow"
        Title="ServerCenter"
        Width="1100" Height="760">
  <Grid Margin="12" RowDefinitions="Auto,*">

    <!-- Connection header (always visible) -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="4,4,4,10">
      <TextBlock Text="Controller" VerticalAlignment="Center" />
      <TextBox Width="320" Text="{Binding ControllerAddress}" PlaceholderText="http://host:5080" />
      <Button Content="Connect" Command="{Binding ConnectCommand}" />
      <TextBlock FontSize="14" Text="{Binding Fleet.ConnectionStatus}" VerticalAlignment="Center" Margin="8,0,0,0" />
    </StackPanel>

    <TabControl Grid.Row="1">

      <!-- ===================== FLEET ===================== -->
      <TabItem Header="Fleet">
        <ScrollViewer>
          <ItemsControl ItemsSource="{Binding Fleet.Nodes}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Width="480" Margin="8" Padding="14" CornerRadius="8" BorderBrush="#3a3a3a" BorderThickness="1">
                  <StackPanel Spacing="8">

                    <!-- header: badges | name | VM controls -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Border Background="#2563eb" CornerRadius="10" Padding="8,2">
                          <TextBlock Text="{Binding Version}" Foreground="White" FontSize="11" />
                        </Border>
                        <Border Background="#f59e0b" CornerRadius="6" Padding="6,2" IsVisible="{Binding RebootPending}">
                          <TextBlock Text="Reboot" Foreground="Black" FontSize="11" />
                        </Border>
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="15" FontWeight="Bold"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                  IsVisible="{Binding IsGuest}">
                        <Button Content="Start" Command="{Binding VmActionCommand}" CommandParameter="start" />
                        <Button Content="Stop" Command="{Binding VmActionCommand}" CommandParameter="stop" />
                        <Button Content="Restart" Command="{Binding VmActionCommand}" CommandParameter="restart" />
                      </StackPanel>
                    </Grid>

                    <!-- sub-header: kind / os / dual-truth / last seen -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Border Background="#374151" CornerRadius="6" Padding="6,2">
                        <TextBlock Text="{Binding Kind}" Foreground="White" FontSize="11" />
                      </Border>
                      <Border Background="#374151" CornerRadius="6" Padding="6,2">
                        <TextBlock Text="{Binding Os}" Foreground="White" FontSize="11" />
                      </Border>
                      <TextBlock Text="{Binding AgentLivenessText, StringFormat='Agent {0}'}" VerticalAlignment="Center" FontSize="12" />
                      <TextBlock Text="{Binding VmStateText, StringFormat='VM {0}'}" VerticalAlignment="Center" FontSize="12" />
                      <TextBlock Text="{Binding LastSeen}" VerticalAlignment="Center" FontSize="12" Foreground="#9ca3af" />
                    </StackPanel>

                    <!-- resource bars -->
                    <Grid ColumnDefinitions="46,*,44" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                      <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU" VerticalAlignment="Center" FontSize="12" />
                      <ProgressBar Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding CpuPct}" Height="12" VerticalAlignment="Center" />
                      <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding CpuPct, StringFormat='{}{0:0}%'}" FontSize="12" HorizontalAlignment="Right" />
                      <TextBlock Grid.Row="1" Grid.Column="0" Text="Mem" VerticalAlignment="Center" FontSize="12" />
                      <ProgressBar Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding MemPct}" Height="12" VerticalAlignment="Center" />
                      <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding MemPct, StringFormat='{}{0:0}%'}" FontSize="12" HorizontalAlignment="Right" />
                      <TextBlock Grid.Row="2" Grid.Column="0" Text="Disk" VerticalAlignment="Center" FontSize="12" />
                      <ProgressBar Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding DiskPct}" Height="12" VerticalAlignment="Center" />
                      <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding DiskPct, StringFormat='{}{0:0}%'}" FontSize="12" HorizontalAlignment="Right" />
                    </Grid>

                    <!-- actions: service restart + update -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <ComboBox Width="170" PlaceholderText="service" ItemsSource="{Binding Services}"
                                SelectedItem="{Binding SelectedService, Mode=TwoWay}" />
                      <Button Content="Restart" Command="{Binding RestartServiceCommand}" />
                      <ComboBox Width="120" PlaceholderText="policy" ItemsSource="{Binding Policies}"
                                SelectedItem="{Binding SelectedPolicy, Mode=TwoWay}" />
                      <Button Content="Update" Command="{Binding RunUpdateCommand}" />
                    </StackPanel>

                    <TextBlock Text="{Binding ActionStatus}" Foreground="#8fbcff" FontSize="12" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </TabItem>

      <!-- ===================== SERVERS ===================== -->
      <TabItem Header="Servers">
        <Grid RowDefinitions="Auto,*,Auto">
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="4,0,4,8">
            <Button Content="Refresh" Command="{Binding Servers.RefreshCommand}" />
            <TextBlock Text="{Binding Servers.Status}" VerticalAlignment="Center" />
          </StackPanel>

          <DataGrid Grid.Row="1"
                    ItemsSource="{Binding Servers.Rows}"
                    SelectedItem="{Binding Servers.SelectedServer, Mode=TwoWay}"
                    IsReadOnly="True" AutoGenerateColumns="False" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Instance" Binding="{Binding Id}" Width="2*" />
              <DataGridTextColumn Header="Node" Binding="{Binding Node}" Width="*" />
              <DataGridTextColumn Header="Descriptor" Binding="{Binding Descriptor}" Width="*" />
              <DataGridTextColumn Header="Recipe" Binding="{Binding Recipe}" Width="*" />
              <DataGridTextColumn Header="Policy" Binding="{Binding Policy}" Width="*" />
            </DataGrid.Columns>
          </DataGrid>

          <Border Grid.Row="2" BorderBrush="#444" BorderThickness="0,1,0,0" Padding="4,10,4,4" Margin="0,8,0,0">
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock FontWeight="Bold" VerticalAlignment="Center"
                           Text="{Binding Servers.SelectedServer.Id, StringFormat='Actions - {0}'}" />
                <Button Content="Install" Command="{Binding Servers.ServerJobCommand}" CommandParameter="server-install" />
                <Button Content="Config apply" Command="{Binding Servers.ServerJobCommand}" CommandParameter="server-config-apply" />
                <Button Content="Recipe apply" Command="{Binding Servers.ServerJobCommand}" CommandParameter="recipe-apply" />
                <TextBlock Text="{Binding Servers.ActionStatus}" VerticalAlignment="Center" Foreground="#8fbcff" />
              </StackPanel>
              <TextBlock Text="Define (paste a descriptor / recipe / instance JSON):" Margin="0,4,0,0" />
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBox Width="560" Height="72" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalContentAlignment="Top" Text="{Binding Servers.DefinitionJson}" />
                <StackPanel Orientation="Vertical" Spacing="4">
                  <Button Content="Store descriptor" Command="{Binding Servers.StoreCommand}" CommandParameter="game-descriptors" />
                  <Button Content="Store recipe" Command="{Binding Servers.StoreCommand}" CommandParameter="build-recipes" />
                  <Button Content="Store instance" Command="{Binding Servers.StoreCommand}" CommandParameter="server-instances" />
                <Button Content="Store policy" Command="{Binding Servers.StoreCommand}" CommandParameter="update-policies" />
                </StackPanel>
                <TextBlock Text="{Binding Servers.DefinitionStatus}" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="300" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>
      </TabItem>

      <!-- ===================== JOBS ===================== -->
      <TabItem Header="Jobs">
        <DataGrid ItemsSource="{Binding Jobs.Jobs}"
                  IsReadOnly="True" AutoGenerateColumns="False" GridLinesVisibility="Horizontal">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Job" Binding="{Binding ShortId}" Width="Auto" />
            <DataGridTextColumn Header="Node" Binding="{Binding NodeId}" Width="*" />
            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="Auto" />
            <DataGridTextColumn Header="State" Binding="{Binding StateText}" Width="Auto" />
            <DataGridTextColumn Header="Progress" Binding="{Binding ProgressText}" Width="Auto" />
            <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="3*" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>

    </TabControl>
  </Grid>
</Window>
