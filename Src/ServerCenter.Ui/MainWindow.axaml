<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ServerCenter.Ui.MainWindow"
        Title="ServerCenter"
        Width="1100" Height="980">
  <Grid Margin="12" RowDefinitions="Auto,2*,Auto,1*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,2*">

    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="4,4,4,8">
      <TextBlock Text="Controller" VerticalAlignment="Center" />
      <TextBox Width="320" Text="{Binding ControllerAddress}" PlaceholderText="http://host:5080" />
      <Button Content="Connect" Command="{Binding ConnectCommand}" />
      <TextBlock FontSize="14" Text="{Binding Fleet.ConnectionStatus}" VerticalAlignment="Center" Margin="8,0,0,0" />
    </StackPanel>

    <DataGrid Grid.Row="1"
              ItemsSource="{Binding Fleet.Nodes}"
              IsReadOnly="True" AutoGenerateColumns="False" GridLinesVisibility="Horizontal">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Node" Binding="{Binding DisplayName}" Width="2*" />
        <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="Auto" />
        <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="Auto" />
        <DataGridTextColumn Header="OS" Binding="{Binding Os}" Width="Auto" />
        <DataGridTextColumn Header="Agent" Binding="{Binding AgentLivenessText}" Width="Auto" />
        <DataGridTextColumn Header="VM" Binding="{Binding VmStateText}" Width="Auto" />
        <DataGridTextColumn Header="Reboot" Binding="{Binding RebootPending}" Width="Auto" />
        <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="Auto" />
        <DataGridTextColumn Header="Resources" Binding="{Binding Resources}" Width="2*" />
      </DataGrid.Columns>
    </DataGrid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="4,14,4,6">
      <TextBlock FontSize="14" FontWeight="Bold" Text="Servers" VerticalAlignment="Center" />
      <Button Content="Refresh" Command="{Binding Servers.RefreshCommand}" />
      <TextBlock Text="{Binding Servers.Status}" VerticalAlignment="Center" />
    </StackPanel>

    <DataGrid Grid.Row="3"
              ItemsSource="{Binding Servers.Rows}"
              IsReadOnly="True" AutoGenerateColumns="False" GridLinesVisibility="Horizontal">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Instance" Binding="{Binding Id}" Width="2*" />
        <DataGridTextColumn Header="Node" Binding="{Binding Node}" Width="*" />
        <DataGridTextColumn Header="Descriptor" Binding="{Binding Descriptor}" Width="*" />
        <DataGridTextColumn Header="Recipe" Binding="{Binding Recipe}" Width="*" />
        <DataGridTextColumn Header="Policy" Binding="{Binding Policy}" Width="*" />
      </DataGrid.Columns>
    </DataGrid>

    <TextBlock Grid.Row="4" Margin="4,14,4,6" FontSize="14" FontWeight="Bold" Text="Jobs" />

    <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="6" Margin="4,0,4,8">
      <TextBox PlaceholderText="agent id" Text="{Binding Jobs.RestartAgentId}" Width="180" />
      <TextBox PlaceholderText="unit (e.g. plex.service)" Text="{Binding Jobs.RestartUnit}" Width="240" />
      <Button Content="Restart service" Command="{Binding Jobs.RestartCommand}" />
      <TextBlock Text="{Binding Jobs.TriggerStatus}" VerticalAlignment="Center" />
    </StackPanel>

    <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="6" Margin="4,0,4,8">
      <TextBox PlaceholderText="agent id" Text="{Binding Jobs.UpdateAgentId}" Width="180" />
      <TextBox PlaceholderText="policy id (e.g. plex-nightly)" Text="{Binding Jobs.UpdatePolicyId}" Width="240" />
      <TextBox PlaceholderText="service unit (optional)" Text="{Binding Jobs.UpdateServiceUnit}" Width="200" />
      <Button Content="Run update" Command="{Binding Jobs.TriggerUpdateCommand}" />
      <TextBlock Text="{Binding Jobs.UpdateStatus}" VerticalAlignment="Center" />
    </StackPanel>

    <StackPanel Grid.Row="7" Orientation="Horizontal" Spacing="6" Margin="4,0,4,8">
      <TextBox PlaceholderText="node id (VM)" Text="{Binding Jobs.VmNodeId}" Width="180" />
      <Button Content="Start" Command="{Binding Jobs.VmActionCommand}" CommandParameter="start" />
      <Button Content="Stop" Command="{Binding Jobs.VmActionCommand}" CommandParameter="stop" />
      <Button Content="Restart" Command="{Binding Jobs.VmActionCommand}" CommandParameter="restart" />
      <TextBlock Text="{Binding Jobs.VmStatus}" VerticalAlignment="Center" />
    </StackPanel>

    <TextBlock Grid.Row="8" Margin="4,14,4,6" FontSize="14" FontWeight="Bold" Text="Manage" />

    <StackPanel Grid.Row="9" Orientation="Horizontal" Spacing="6" Margin="4,0,4,8">
      <TextBox PlaceholderText="node id" Text="{Binding Manage.LinkNodeId}" Width="180" />
      <TextBox PlaceholderText="libvirt domain" Text="{Binding Manage.LinkDomain}" Width="200" />
      <Button Content="Link VM domain" Command="{Binding Manage.LinkDomainCommand}" />
      <TextBlock Text="{Binding Manage.LinkStatus}" VerticalAlignment="Center" />
    </StackPanel>

    <StackPanel Grid.Row="10" Orientation="Horizontal" Spacing="6" Margin="4,0,4,8">
      <TextBox PlaceholderText="paste a descriptor / recipe / instance JSON"
               Text="{Binding Manage.DefinitionJson}" Width="430" Height="64"
               AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" />
      <StackPanel Orientation="Vertical" Spacing="4">
        <Button Content="Store descriptor" Command="{Binding Manage.StoreCommand}" CommandParameter="game-descriptors" />
        <Button Content="Store recipe" Command="{Binding Manage.StoreCommand}" CommandParameter="build-recipes" />
        <Button Content="Store instance" Command="{Binding Manage.StoreCommand}" CommandParameter="server-instances" />
      </StackPanel>
      <TextBlock Text="{Binding Manage.DefinitionStatus}" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="360" />
    </StackPanel>

    <StackPanel Grid.Row="11" Orientation="Horizontal" Spacing="6" Margin="4,0,4,8">
      <TextBox PlaceholderText="agent id" Text="{Binding Manage.ServerAgentId}" Width="180" />
      <TextBox PlaceholderText="instance id" Text="{Binding Manage.ServerInstanceId}" Width="200" />
      <Button Content="Install" Command="{Binding Manage.ServerJobCommand}" CommandParameter="server-install" />
      <Button Content="Config apply" Command="{Binding Manage.ServerJobCommand}" CommandParameter="server-config-apply" />
      <Button Content="Recipe apply" Command="{Binding Manage.ServerJobCommand}" CommandParameter="recipe-apply" />
      <TextBlock Text="{Binding Manage.ServerStatus}" VerticalAlignment="Center" />
    </StackPanel>

    <DataGrid Grid.Row="12"
              ItemsSource="{Binding Jobs.Jobs}"
              IsReadOnly="True" AutoGenerateColumns="False" GridLinesVisibility="Horizontal">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Job" Binding="{Binding ShortId}" Width="Auto" />
        <DataGridTextColumn Header="Node" Binding="{Binding NodeId}" Width="*" />
        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="Auto" />
        <DataGridTextColumn Header="State" Binding="{Binding StateText}" Width="Auto" />
        <DataGridTextColumn Header="Progress" Binding="{Binding ProgressText}" Width="Auto" />
        <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="3*" />
      </DataGrid.Columns>
    </DataGrid>

  </Grid>
</Window>
