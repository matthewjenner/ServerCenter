# ServerCenter Agent configuration (read by the systemd unit's EnvironmentFile).
# The SAME agent runs on every node; only these values differ per node.

# Controller address. https enables mTLS (the normal case); http is plaintext dev only.
SERVERCENTER_CONTROLLER=https://your-controller-host:5443

# One-time enrollment token minted by the controller, delivered out-of-band (this file / SSH).
# Needed only on first start; after enrollment the agent reuses its persisted cert.
SERVERCENTER_ENROLL_TOKEN=

# Node kind: "guest" for a normal managed VM (default if unset), "host" for node zero (the
# agent running natively on the hypervisor host). This is only a label reported to the
# controller; it does not change the agent. The host's extra behavior comes from controller
# policy, not different agent code.
SERVERCENTER_NODE_KIND=guest

# Plaintext (http) only: the stable node id. Must be UNIQUE per node - if left blank every
# plaintext node collides on the id "dev-agent". Ignored over https/mTLS, where identity comes
# from the enrolled certificate instead. (install.sh --with-controller sets this to "host".)
SERVERCENTER_AGENT_ID=

# Where the enrolled identity (cert + key + CA) is persisted. Under the systemd StateDirectory.
SERVERCENTER_CERT_DIR=/var/lib/servercenter-agent/identity

# Optional display name (defaults to the machine hostname).
#SERVERCENTER_AGENT_NAME=
